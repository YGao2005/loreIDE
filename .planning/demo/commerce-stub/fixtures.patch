+// Fixture data for running vercel/commerce without a Shopify backend.
+// Used as fallback when SHOPIFY_STORE_DOMAIN is empty or unset.
+// Shape matches the reshaped Shopify types returned by lib/shopify/index.ts.
+
+import type { Cart, Collection, Menu, Page, Product } from "./types";
+
+const img = (w: number, h: number, seed: string) => ({
+  url: `https://picsum.photos/seed/${seed}/${w}/${h}`,
+  altText: seed,
+  width: w,
+  height: h,
+});
+
+const money = (amount: string) => ({ amount, currencyCode: "USD" });
+
+const mkProduct = (
+  handle: string,
+  title: string,
+  description: string,
+  price: string,
+  seed: string,
+  tags: string[] = []
+): Product => {
+  const variantId = `gid://shopify/ProductVariant/${handle}-default`;
+  return {
+    id: `gid://shopify/Product/${handle}`,
+    handle,
+    availableForSale: true,
+    title,
+    description,
+    descriptionHtml: `<p>${description}</p>`,
+    options: [
+      {
+        id: `gid://shopify/ProductOption/${handle}-size`,
+        name: "Size",
+        values: ["S", "M", "L", "XL"],
+      },
+    ],
+    priceRange: {
+      minVariantPrice: money(price),
+      maxVariantPrice: money(price),
+    },
+    variants: [
+      {
+        id: variantId,
+        title: "M",
+        availableForSale: true,
+        selectedOptions: [{ name: "Size", value: "M" }],
+        price: money(price),
+      },
+    ],
+    featuredImage: img(800, 800, seed),
+    images: [img(1200, 1200, seed), img(1200, 1200, `${seed}-2`)],
+    seo: { title, description },
+    tags,
+    updatedAt: "2026-04-24T00:00:00Z",
+  };
+};
+
