+export const PAGES: Page[] = [];
+
+// In-memory cart for stubbed mutations.
+// Not persistent across process restarts — fine for demo.
+const CART_STATE: Cart = {
+  id: "gid://shopify/Cart/stub-cart",
+  checkoutUrl: "https://example.com/checkout",
+  cost: {
+    subtotalAmount: money("0.00"),
+    totalAmount: money("0.00"),
+    totalTaxAmount: money("0.00"),
+  },
+  lines: [],
+  totalQuantity: 0,
+};
+
+function recomputeCartCost() {
+  const subtotal = CART_STATE.lines.reduce(
+    (sum, l) => sum + parseFloat(l.cost.totalAmount.amount),
+    0
+  );
+  CART_STATE.cost.subtotalAmount = money(subtotal.toFixed(2));
+  CART_STATE.cost.totalAmount = money(subtotal.toFixed(2));
+  CART_STATE.totalQuantity = CART_STATE.lines.reduce(
+    (n, l) => n + l.quantity,
+    0
+  );
+}
+
+export function fixtureGetCart(): Cart {
+  return JSON.parse(JSON.stringify(CART_STATE));
+}
+
+export function fixtureAddToCart(
+  lines: { merchandiseId: string; quantity: number }[]
+): Cart {
+  for (const { merchandiseId, quantity } of lines) {
+    const product = PRODUCTS.find((p) =>
+      p.variants.some((v) => v.id === merchandiseId)
+    );
+    const variant = product?.variants.find((v) => v.id === merchandiseId);
+    if (!product || !variant) continue;
+    const unitPrice = parseFloat(variant.price.amount);
+    const line = {
+      id: `line-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`,
+      quantity,
+      cost: { totalAmount: money((unitPrice * quantity).toFixed(2)) },
+      merchandise: {
+        id: variant.id,
+        title: variant.title,
+        selectedOptions: variant.selectedOptions,
+        product: {
+          id: product.id,
+          handle: product.handle,
+          title: product.title,
+          featuredImage: product.featuredImage,
+        },
+      },
+    };
+    CART_STATE.lines.push(line);
+  }
+  recomputeCartCost();
+  return fixtureGetCart();
+}
+
+export function fixtureRemoveFromCart(lineIds: string[]): Cart {
+  CART_STATE.lines = CART_STATE.lines.filter(
+    (l) => !l.id || !lineIds.includes(l.id)
+  );
+  recomputeCartCost();
+  return fixtureGetCart();
+}
+
+export function fixtureUpdateCart(
+  lines: { id: string; merchandiseId: string; quantity: number }[]
+): Cart {
+  for (const { id, quantity } of lines) {
+    const line = CART_STATE.lines.find((l) => l.id === id);
+    if (!line) continue;
+    const unitAmount =
+      parseFloat(line.cost.totalAmount.amount) / (line.quantity || 1);
+    line.quantity = quantity;
+    line.cost.totalAmount = money((unitAmount * quantity).toFixed(2));
+  }
+  recomputeCartCost();
+  return fixtureGetCart();
+}
+
+export function fixtureCreateCart(): Cart {
+  CART_STATE.lines = [];
+  recomputeCartCost();
+  return fixtureGetCart();
+}
