+    "Acme Heavyweight Tote",
+    "16 oz canvas tote, reinforced stitching, leather handles.",
+    "48.00",
+    "tote-heavy",
+    ["accessories", "featured"]
+  ),
+  mkProduct(
+    "acme-mug",
+    "Acme Ceramic Mug",
+    "12 oz stoneware, hand-glazed in small batches.",
