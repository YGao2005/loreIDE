{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "contract-ide",
  "version": "0.1.0",
  "identifier": "com.contract-ide.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Contract IDE",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 12, "y": 14 },
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'"],
        "script-src": ["'self'", "blob:"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "img-src": ["'self'", "data:", "asset:", "https://asset.localhost"],
        "connect-src": ["'self'", "ipc:", "https://ipc.localhost"],
        "frame-src": ["http://localhost:*", "http://127.0.0.1:*"]
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:contract-ide.db"]
    },
    "fs": {
      "requireLiteralLeadingDot": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/mcp-server", "binaries/section-parser-cli"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
