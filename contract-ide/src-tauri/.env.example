# Substrate rerank — used by retrieval/rerank.rs during the Delegate compose
# step. Without this key, retrieval falls back to FTS5+RRF ordering (still
# correct, just less accurate ordering on top-15 → top-5 selection).
#
# Sign up at https://platform.deepseek.com — keys start with `sk-`.
# Model: deepseek-v4-flash (non-thinking mode). ~$0.0001 per rerank call.
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
